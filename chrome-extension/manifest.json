{
  "manifest_version": 3,
  "name": "ToneLayer",
  "version": "0.1.0",
  "description": "Rewrite selected text from ND style into NT-readable communication.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "ToneLayer"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://tonelayer-server-production.up.railway.app/*"
  ]
}
